---
export interface Props {
	title: string;
	description?: string;
    canonicalUrl?: string;
}

const { title, description = "Premium SEO, Web Development, and SMM services for the Pakistani market.", canonicalUrl } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="theme-color" content="#cc785c">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="keywords" content="SEO Ustaad, SEO Pakistan, Web Development Pakistan, Shopify Expert Pakistan, Meta Ads Agency Karachi, AEO Services">
    <meta name="author" content="SEO Ustaad">
    <meta name="google-site-verification" content="J4uC8-bUoYUWMCuTTF1GRu_E5DQq_OKpVTbnpDbCfaI">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content="/images/logo.svg">
    <meta property="og:url" content={canonicalUrl || Astro.url}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.min.css">
    
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" href="/favicon.ico">
    <link rel="manifest" href="/site.webmanifest">
    <meta property="og:image" content="https://seoustaad.com/og-image.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="https://seoustaad.com/og-image.png">
</head>
<body>
    <slot name="header" />
    <slot />
    <slot name="footer" />
    <slot name="widget" />
    
    <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script is:inline src="/script.min.js"></script>
</body>
</html>
