---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappWidget from '../components/WhatsappWidget.astro';
import FAQ from '../components/FAQ.astro';
import LeadForm from '../components/LeadForm.astro';
---

<Layout title="SEO Ustaad | Dominate Digital Search in Pakistan | SEO, Web Dev & SMM" description="SEO Ustaad is Pakistan's top-rated Generative Engine Optimization & Web Development agency. Scale your brand with affordable WordPress developers and ROI-driven SEO starting at 5,000 PKR. Order via WhatsApp today." canonicalUrl="https://seoustaad.com/">
    <Header slot="header" />
    
    <header class="hero-section">
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="container position-relative z-2">
        <div class="row align-items-center g-5">
          <div class="col-lg-6 order-1 text-center text-lg-start stagger-reveal stagger-delay-1">
            <h5 class="text-orange fw-bold mb-3 text-uppercase tracking-wider">#1 Digital Agency in Pakistan</h5>
            <h1 class="display-4 outfit mb-3 fw-bold">Dominate Digital Search<br><span class="text-gradient">With SEO Ustaad</span></h1>
            <p class="lead text-gray mb-4">Premium Web Development, ROI-Driven SEO, and Meta Ads specialized for the Pakistani market. We don't just build sites; we build search authority.</p>
            <div class="d-none d-lg-flex flex-column flex-sm-row justify-content-lg-start gap-3 mb-4 font-outfit">
              <a href="#packages" class="btn btn-orange btn-lg px-4 py-3 fw-bold">View 40+ Packages</a>
              <a href="#calculator" class="btn btn-orange btn-lg px-4 py-3 fw-bold">Calculate Growth</a>
            </div>
            <div class="d-none d-lg-flex align-items-center justify-content-lg-start gap-3 mt-4">
              <div class="avatar-group">
                <span class="avatar-init" style="background-color:var(--primary-orange)">A</span>
                <span class="avatar-init" style="background-color:#3b5998">Z</span>
                <span class="avatar-init" style="background-color:#25d366">F</span>
                <span class="avatar-init" style="background-color:#0077b5">H</span>
              </div>
              <div class="text-start">
                <div class="text-warning small mb-1">
                  <i class="fas fa-star"></i> <i class="fas fa-star"></i> <i class="fas fa-star"></i> <i class="fas fa-star"></i> <i class="fas fa-star"></i>
                  <span class="ms-2 fw-bold">4.9/5</span>
                </div>
                <span class="text-gray small">Trusted by 1,000+ businesses in Pakistan</span>
              </div>
            </div>
          </div>
          <div class="col-lg-6 order-2 stagger-reveal stagger-delay-3">
            <LeadForm />
          </div>
        </div>
      </div>
      <div class="hero-glow"></div>
      <div class="hero-grid"></div>
    </header>

    <!-- The rest of the sections like services, calculator, packages, etc remain unchanged -->
    <section id="services" class="py-5">
      <!-- Unchanged Service cards -->
      <div class="container py-5">
        <div class="text-center mb-5 stagger-reveal">
          <h2 class="outfit display-5">Our Specialized <span class="text-orange">Services</span></h2>
          <p class="text-gray">Tailored digital solutions designed to dominate the 2026 search landscape.</p>
        </div>
        <div class="row g-4 justify-content-center">
          <div class="col-md-6 col-lg-4 stagger-reveal">
            <div class="service-card p-4 p-md-5 h-100 d-flex flex-column">
              <div class="service-card-spotlight"></div>
              <div class="service-icon mb-4"><i class="fas fa-code"></i></div>
              <h3 class="outfit h4 mb-3">Web Development</h3>
              <ul class="list-unstyled text-gray small mb-4">
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> Custom WordPress Themes</li>
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> Shopify Liquid Mastery</li>
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> React &amp; Next.js Apps</li>
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> Flutter Mobile Apps</li>
              </ul>
              <div class="mt-auto pt-3 border-top border-white border-opacity-10"><button class="btn btn-outline-orange w-100 py-2 rounded-pill fw-bold btn-sm explore-service-btn" data-category="web">Explore Packages <i class="fas fa-arrow-right ms-2 transition-200"></i></button></div>
            </div>
          </div>
          <div class="col-md-6 col-lg-4 stagger-reveal">
            <div class="service-card p-4 p-md-5 h-100 highlight-card d-flex flex-column">
              <div class="service-card-spotlight"></div>
              <div class="service-icon mb-4"><i class="fas fa-search"></i></div>
              <h3 class="outfit h4 mb-3">SEO &amp; AEO</h3>
              <ul class="list-unstyled text-gray small mb-4">
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> Technical SEO Audits</li>
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> Local SEO Domination</li>
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> Answer Engine Opt. (AEO)</li>
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> E-commerce SEO Growth</li>
              </ul>
              <div class="mt-auto pt-3 border-top border-white border-opacity-10"><button class="btn btn-outline-orange w-100 py-2 rounded-pill fw-bold btn-sm explore-service-btn" data-category="seo">Explore Packages <i class="fas fa-arrow-right ms-2 transition-200"></i></button></div>
            </div>
          </div>
          <div class="col-md-6 col-lg-4 stagger-reveal">
            <div class="service-card p-4 p-md-5 h-100 d-flex flex-column">
              <div class="service-card-spotlight"></div>
              <div class="service-icon mb-4"><i class="fas fa-bullhorn"></i></div>
              <h3 class="outfit h4 mb-3">SMM &amp; Meta Ads</h3>
              <ul class="list-unstyled text-gray small mb-4">
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> High-ROAS Meta Ads</li>
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> Video Reels Production</li>
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> Account Management</li>
                <li class="mb-2"><i class="fas fa-check text-orange me-2"></i> Lead Generation Funnels</li>
              </ul>
              <div class="mt-auto pt-3 border-top border-white border-opacity-10"><button class="btn btn-outline-orange w-100 py-2 rounded-pill fw-bold btn-sm explore-service-btn" data-category="marketing">Explore Packages <i class="fas fa-arrow-right ms-2 transition-200"></i></button></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Growth calculator -->
    <section id="calculator" class="py-5 bg-darker">
      <div class="container py-5">
        <div class="row align-items-center">
          <div class="col-lg-6 mb-5 mb-lg-0 stagger-reveal">
            <h2 class="outfit display-5 mb-4 text-white">How Much Can <span class="text-orange">You Grow?</span></h2>
            <p class="text-gray mb-4">Adjust the sliders below to see your potential monthly growth based on SEO Ustaad's data from 1,000+ local Pakistani campaigns.</p>
            <div class="calc-card p-3 p-sm-4 glass-card">
              <div class="mb-4">
                <label class="form-label d-flex justify-content-between"><span>Monthly Budget (PKR)</span> <span class="text-orange fw-bold" id="budgetValue">15,000 PKR</span></label>
                <input type="range" class="form-range custom-range" id="budgetRange" min="5000" max="30000" step="1000" value="15000">
              </div>
              <div class="mb-4">
                <label class="form-label">Select Service</label>
                <select class="form-select glass-input" id="serviceSelect">
                  <optgroup label="Web Development">
                    <option value="website-speed-optimization">Website Speed Optimization</option>
                    <option value="ecommerce-bug-fixing">E-Commerce Bug Fixing &amp; Tweaks</option>
                    <option value="premium-custom-wordpress-website">Premium Custom WordPress development full website</option>
                    <option value="premium-custom-shopify-store">Premium custom Shopify Store development and Setup</option>
                    <option value="custom-nextjs-website">Custom Next.js full website [for any niche]</option>
                  </optgroup>
                  <optgroup label="Technical SEO">
                    <option value="disavow-toxic-backlinks">Premium Disavow Toxic Backlinks &amp; Penalty Recovery</option>
                    <option value="premium-schema-markup">Premium Schema Markup &amp; Advanced Structured Data</option>
                    <option value="comprehensive-keyword-research">Comprehensive Keyword Research &amp; Competitor Gap Analysis</option>
                    <option value="premium-technical-seo-audit">Premium Technical SEO Audit &amp; Action Plan</option>
                    <option value="complete-onpage-seo-optimization">Complete On-Page SEO Optimization [up to 10 Pages]</option>
                    <option value="advanced-core-web-vitals">Advanced Core Web Vitals &amp; PageSpeed Fixes</option>
                  </optgroup>
                  <optgroup label="Local SEO">
                    <option value="premium-local-citations">Premium Local Citations &amp; High-DA Directory Listings</option>
                    <option value="premium-gmb-setup">Premium Google Business Profile (GMB) Setup &amp; Ranking</option>
                    <option value="geo-targeted-landing-page-copy">Highly-Converting Geo-Targeted Landing Page Copywriting</option>
                    <option value="premium-local-seo-retainer">Premium Local SEO Monthly Retainer [Dominate your City]</option>
                  </optgroup>
                  <optgroup label="E-Commerce">
                    <option value="premium-ecommerce-product-seo">Premium Shopify/WooCommerce Product SEO [20 Products]</option>
                    <option value="complete-ecommerce-category-seo">Complete E-Commerce Category Page Optimization</option>
                    <option value="advanced-cro-audit">Advanced Conversion Rate Optimization (CRO) Audit</option>
                    <option value="premium-ecommerce-architecture">Premium E-Commerce Architecture &amp; Silo Restructure</option>
                  </optgroup>
                  <optgroup label="Social Media &amp; Ads">
                    <option value="premium-web20-backlinks">10 Premium Foundation Web 2.0 Backlinks</option>
                    <option value="competitor-backlink-intercept">Advanced Competitor Backlink Intercept Strategy</option>
                    <option value="high-converting-ad-copywriting">High-Converting Ad Copywriting &amp; Creative Strategy</option>
                    <option value="premium-meta-ads-campaign">Premium Meta Ads Campaign Setup &amp; Targeting</option>
                    <option value="high-dr-guest-posts">5 Ultra High-DR Guest Post Backlinks [Contextual]</option>
                    <option value="premium-social-media-management">Premium Social Media Management [Full Month / 3 Posts Wk]</option>
                  </optgroup>
                </select>
              </div>
              <div class="mb-4">
                <label class="form-label">Target Location</label>
                <select class="form-select glass-input" id="locationSelect">
                  <option value="karachi">Karachi</option>
                  <option value="lahore">Lahore</option>
                  <option value="faisalabad">Faisalabad</option>
                  <option value="rawalpindi">Rawalpindi</option>
                  <option value="gujranwala">Gujranwala</option>
                  <option value="peshawar">Peshawar</option>
                  <option value="multan">Multan</option>
                  <option value="hyderabad">Hyderabad</option>
                  <option value="islamabad">Islamabad</option>
                  <option value="quetta">Quetta</option>
                  <option value="bahawalpur">Bahawalpur</option>
                  <option value="sargodha">Sargodha</option>
                  <option value="sialkot">Sialkot</option>
                  <option value="sukkur">Sukkur</option>
                  <option value="larkana">Larkana</option>
                  <option value="sheikhupura">Sheikhupura</option>
                  <option value="rahim-yar-khan">Rahim Yar Khan</option>
                  <option value="jhang">Jhang</option>
                  <option value="dera-ghazi-khan">Dera Ghazi Khan</option>
                  <option value="gujrat">Gujrat</option>
                  <option value="sahiwal">Sahiwal</option>
                  <option value="wah-cantonment">Wah Cantonment</option>
                  <option value="mardan">Mardan</option>
                  <option value="kasur">Kasur</option>
                  <option value="okara">Okara</option>
                </select>
              </div>
            </div>
          </div>
          <div class="col-lg-5 offset-lg-1 stagger-reveal">
            <div class="results-box p-4 p-md-5 text-center mt-4 mt-lg-0">
              <div class="mb-4">
                <p class="text-white-50 small text-uppercase fw-bold mb-1">Estimated Monthly Visitors</p>
                <h2 class="display-4 fw-bold text-white" id="resVisitors">4,500+</h2>
              </div>
              <div class="mb-4">
                <p class="text-white-50 small text-uppercase fw-bold mb-1">Potential New Leads</p>
                <h2 class="display-4 fw-bold text-orange" id="resLeads">225</h2>
              </div>
              <div class="mb-4">
                <p class="text-white-50 small text-uppercase fw-bold mb-1">Estimated Ranking Timeline</p>
                <h2 class="h3 fw-bold text-white mb-3" id="resTime">90 - 120 Days</h2>
              </div>
              <div class="px-2 mb-4 text-start">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <span class="text-gray x-small text-uppercase fw-bold">Growth Velocity</span>
                  <span class="text-orange x-small fw-bold" id="growthVelocityLabel">Starter Plan</span>
                </div>
                <div class="progress bg-darker rounded-pill" style="height:6px;overflow:hidden">
                  <div class="progress-bar bg-orange rounded-pill" role="progressbar" id="growthSpeedBar" style="width:10%;transition:width .4s ease"></div>
                </div>
              </div>
              <hr class="border-white border-opacity-10 my-4">
              <p class="small text-gray italic mb-4">"This is a conservative estimate based on 2026 search trends in Pakistan."</p>
              <a rel="nofollow noopener noreferrer" href="https://wa.me/923146348900" id="calcOrderBtn" class="btn btn-orange w-100 py-3 fw-bold">Get This Growth Plan</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Packages and FAQs -->
    <FAQ count={5} category="general" city="Pakistan" gigName="digital marketing services" />
    <Footer slot="footer" />
    <WhatsappWidget slot="widget" />
</Layout>
