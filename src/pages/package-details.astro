---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappWidget from '../components/WhatsappWidget.astro';
---

<Layout title="Package Details | SEO Ustaad" description="View the comprehensive details, pricing, and deliverables for your selected SEO, Web Development, or Social Media package at SEO Ustaad." canonicalUrl="https://seoustaad.com/package-details/">
    <Header slot="header" />
    
    <div id="loadingOverlay" class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="z-index:9999;background:var(--surface-dark);transition:opacity .5s ease"><div class="spinner-border text-orange" role="status"></div></div><main class="container py-5 mt-5" id="mainContent" style="opacity:0;transform:translateY(20px);transition:all .6s ease"><div class="row justify-content-center pt-5"><div class="col-lg-8 text-center mb-5" id="headerContent"><span id="detailTier" class="tier-badge mb-3 d-inline-block">Loading...</span><h1 id="detailName" class="display-3 outfit mb-3">Package Name</h1><p id="detailService" class="text-orange fw-bold h4 mb-4">Service Type</p><div class="d-flex justify-content-center align-items-center gap-2 mb-3"><i class="fas fa-map-marker-alt text-orange"></i> <span class="text-gray small me-1">Targeting Market:</span> <select id="headerCitySelector" class="form-select glass-input py-2 px-3 rounded-pill small text-center" style="width:auto;background-color:rgba(26,29,33,.85);border-color:rgba(255,102,0,.35);font-size:.9rem;font-weight:600"></select></div></div><div class="col-lg-10" id="notFoundMessage" style="display:none"><div class="glass-card p-3 p-sm-4 p-md-5 text-center"><h2 class="outfit mb-4">Package Not Found</h2><p class="text-gray mb-4">The package you are looking for might have been moved or renamed.</p><a href="/#packages" class="btn btn-orange px-5">Browse All Packages</a></div></div><div class="col-lg-10" id="packageContent"><div class="glass-card p-3 p-sm-4 p-md-5"><div class="row g-5"><div class="col-md-7"><h3 class="outfit h4 mb-4">What's Included:</h3><ul id="detailFeatures" class="list-unstyled text-gray"></ul></div><div class="col-md-5"><div class="results-box p-3 p-sm-4 text-center"><p class="text-gray small text-uppercase mb-1">Fixed Package Price</p><h2 class="display-4 fw-bold text-white mb-0" id="detailPrice">$0</h2><p class="text-orange fw-bold" id="detailPkr">~0 PKR</p><hr class="border-white border-opacity-10 my-4"><ul class="list-unstyled text-start small mb-4"><li class="mb-2"><i class="fas fa-clock text-orange me-2"></i> 24/7 Priority Support</li><li class="mb-2"><i class="fas fa-rocket text-orange me-2"></i> Fast Delivery Guarantee</li><li class="mb-2"><i class="fas fa-shield-alt text-orange me-2"></i> 100% Satisfaction</li></ul><a href="javascript:void(0)" id="detailWaBtn" class="btn btn-orange w-100 py-3 fw-bold pulsing">Order via WhatsApp</a></div></div></div><div class="row mt-5 pt-5 border-top border-white border-opacity-10"><div class="col-12 text-center mb-4"><h3 class="outfit h4 mb-3">Project <span class="text-orange">Timeline</span></h3><p class="text-gray small">A transparent roadmap from start to finish.</p></div><div class="col-md-4 mb-4 mb-md-0"><div class="glass-card p-3 p-sm-4 text-center h-100"><div class="h3 text-orange mb-2"><i class="fas fa-search"></i></div><h5 class="outfit">Discovery &amp; Audit</h5><p class="text-gray small mb-0" id="timelinePhase1">Days 1-3: Strategic planning and niche competitor analysis.</p></div></div><div class="col-md-4 mb-4 mb-md-0"><div class="glass-card p-3 p-sm-4 text-center h-100"><div class="h3 text-orange mb-2"><i class="fas fa-pencil-ruler"></i></div><h5 class="outfit">Implementation</h5><p class="text-gray small mb-0" id="timelinePhase2">Days 4-14: Technical development or campaign setup.</p></div></div><div class="col-md-4"><div class="glass-card p-3 p-sm-4 text-center h-100 highlight-card"><div class="h3 text-orange mb-2"><i class="fas fa-chart-line"></i></div><h5 class="outfit">Results &amp; Scaling</h5><p class="text-gray small mb-0" id="timelinePhase3">Days 15+: Continuous optimization and ranking growth.</p></div></div></div></div><div class="glass-card p-4 p-md-5 mb-4 mt-4" id="localizedGeoStrategy"><h4 class="outfit mb-3"><i class="fas fa-globe text-orange me-2"></i> Localized Market Strategy</h4><p class="text-gray small mb-0" id="geoStrategyText">Loading local marketing parameters...</p></div><div class="glass-card p-4 p-md-5 bg-orange bg-opacity-5 border border-orange border-opacity-20" id="conversationalAeoBlock"><h4 class="outfit text-orange mb-3"><i class="fas fa-microphone text-orange me-2"></i> Voice &amp; AI Search Summary (AEO)</h4><div class="aeo-qa-item"><p class="fw-bold mb-1" id="aeoQuestion">Question: Who provides the best SEO services in Karachi, Pakistan?</p><p class="text-gray small mb-0" id="aeoAnswer">Answer: Loading localized voice query answers...</p></div></div></div></div></main><button type="button" class="back-to-top-float" id="backToTopBtn" aria-label="Scroll to top"><i class="fas fa-arrow-up"></i></button><div class="modal fade glass-modal" id="packageDetailsModal" tabindex="-1" aria-labelledby="packageDetailsModalLabel" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content glass-card border border-white border-opacity-10 border-opacity-25 rounded-4 text-white"><div class="modal-header border-bottom border-white border-opacity-10 border-opacity-25 p-4"><div class="d-flex align-items-center gap-2"><span class="badge bg-orange bg-opacity-10 text-orange border border-orange border-opacity-25 px-2 py-1 rounded-pill small" id="modalPackageTier">Tier 1</span><h5 class="modal-title outfit fw-bold" id="packageDetailsModalLabel">Package Name</h5></div><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body p-4" id="modalPackageBody"></div><div class="modal-footer border-top p-4"><button type="button" class="btn btn-outline-dark btn-sm px-4 py-2 rounded-pill fw-semibold" data-bs-dismiss="modal">Close</button> <a href="javascript:void(0)" id="modalOrderBtn" target="_blank" class="btn btn-orange btn-sm px-4 py-2 rounded-pill fw-bold">Order Now</a></div></div></div></div><script is:inline src="/script.js"></script>
    
    <Footer slot="footer" />
    <WhatsappWidget slot="widget" />
</Layout>
