---
export interface ReviewItem {
  author: string;
  ratingValue: number;
  reviewBody: string;
  datePublished: string;
}

export interface Props {
  serviceName: string;
  serviceDescription: string;
  providerName?: string;
  ratingValue: number;
  reviewCount: number;
  reviews?: ReviewItem[];
}

const {
  serviceName,
  serviceDescription,
  providerName = "SEO Ustaad",
  ratingValue,
  reviewCount,
  reviews = []
} = Astro.props;

const siteUrl = "https://seoustaad.com";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": serviceName,
  "description": serviceDescription,
  "provider": {
    "@type": "ProfessionalService",
    "name": providerName,
    "url": siteUrl,
    "logo": `${siteUrl}/images/logo.svg`
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": ratingValue.toFixed(1),
    "bestRating": "5",
    "worstRating": "1",
    "ratingCount": reviewCount
  },
  ...(reviews.length > 0 && {
    "review": reviews.map((r) => ({
      "@type": "Review",
      "author": {
        "@type": "Person",
        "name": r.author
      },
      "datePublished": r.datePublished,
      "reviewBody": r.reviewBody,
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": r.ratingValue.toString(),
        "bestRating": "5",
        "worstRating": "1"
      }
    }))
  })
};

const schemaJson = JSON.stringify(schema);
---

<script type="application/ld+json" set:html={schemaJson} />
